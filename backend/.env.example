# MQTT Broker configuration (set to "mosquitto" when running inside docker-compose)
MQTT_HOST=localhost
MQTT_PORT=1883

# Google OAuth2 Credentials (Google Calendar, Google Tasks)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-subdomain.ngrok-free.dev/google/callback

# Spotify OAuth2 Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://your-subdomain.ngrok-free.dev/spotify/callback

# Stocks (AlphaVantage or Yahoo Finance API settings)
STOCK_API_KEY=your_stock_api_key
# Comma-separated watchlist, e.g. "CPALL.BK,BTC-USD,GC=F"
STOCK_WATCHLIST=CPALL.BK,BTC-USD,GC=F

# GCP Billing & Analytics
# Path to GCP service account json inside container, e.g. "/app/keys/gcp-sa.json"
GCP_SERVICE_ACCOUNT_PATH=
# Comma-separated GCP project IDs to track billing for, e.g. "my-project-1,my-project-2"
GCP_BILLING_PROJECT_IDS=my-project-1

# GA4 and Google Search Console
GA4_PROPERTY_ID=your_ga4_property_id
GSC_SITE_URL=https://yourwebsite.com

# ngrok configuration (Optional, for secure local API tunneling)
NGROK_AUTHTOKEN=your_ngrok_authtoken
